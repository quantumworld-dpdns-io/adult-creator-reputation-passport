# Service Configuration
ENVIRONMENT=development
LOG_LEVEL=info

# Go API Service
GO_API_PORT=8080
GO_API_LOG_LEVEL=info

# Rust Data Service
RUST_DATA_PORT=8081
RUST_DATA_LOG_LEVEL=info

# Python AI Service
PYTHON_AI_PORT=8082
PYTHON_AI_LOG_LEVEL=info

# Julia Analytics Service
JULIA_ANALYTICS_PORT=8083
JULIA_ANALYTICS_LOG_LEVEL=info

# QASM Quantum Service
QASM_PORT=8084

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=reputation_passport
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# NATS
NATS_HOST=localhost
NATS_PORT=4222

# MinIO (S3-compatible)
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Kong Gateway
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000

# AI Services
OLLAMA_HOST=http://localhost:11434
VLLM_HOST=http://localhost:8000
SGLANG_HOST=http://localhost:30000

# Vector Databases
CHROMA_HOST=http://localhost:8000
QDRANT_HOST=http://localhost:6333
MILVUS_HOST=http://localhost:19530
WEAVIATE_HOST=http://localhost:8080

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
WEAVE_API_KEY=
WANDB_API_KEY=

# Blockchain
ETHEREUM_RPC_URL=http://localhost:8545
ETHEREUM_PRIVATE_KEY=
CONTRACT_ADDRESS=

# JWT
JWT_SECRET=changeme-jwt-secret-min-32-chars-long
JWT_EXPIRY_HOURS=24

# TLS/SSL
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
