root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{go,go.mod,go.sum}]
indent_style = tab
indent_size = 8

[*.{rs,toml}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json}]
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 8

[*.md]
trim_trailing_whitespace = false
